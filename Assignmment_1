#include <iostream>
#include <string>

using namespace std;

// PART A: Class Design
class BankAccount {
private:
    int accountNumber;
    string accountHolder;
    double balance;

public:
    // PART B: Constructor
    // Initializes the account details upon creation
    BankAccount(int accNum, string name, double initialBalance) {
        accountNumber = accNum;
        accountHolder = name;
        balance = initialBalance;
    }

    // PART C: Member Functions
    
    // 1. Deposit money
    void deposit(double amount) {
        if (amount > 0) {
            balance += amount;
            cout << "Deposit: " << amount << endl;
            cout << "New Balance: " << balance << endl;
        }
    }

    // 2. Withdraw money with insufficient funds check
    void withdraw(double amount) {
        if (amount > balance) {
            cout << "Withdrawal of " << amount << " failed: Insufficient funds!" << endl;
        } else if (amount > 0) {
            balance -= amount;
            cout << "Withdrawal: " << amount << endl;
            cout << "New Balance: " << balance << endl;
        }
    }

    // 3. Display account details
    void displayAccount() {
        cout << "------------------------------" << endl;
        cout << "Account Number: " << accountNumber << endl;
        cout << "Account Holder: " << accountHolder << endl;
        cout << "Balance: " << balance << endl;
        cout << "------------------------------" << endl;
    }
};

// PART D: Main Function
int main() {
    // 1. Create at least 2 BankAccount objects
    BankAccount account1(101, "John", 5000);
    BankAccount account2(102, "Sarah", 3000);

    // Display initial state of Account 1
    account1.displayAccount();

    // 2. Perform transactions for Account 1
    account1.deposit(1000);     // One deposit
    cout << endl;
    account1.withdraw(2000);    // One withdrawal

    // 3. Display updated information
    cout << "\nUpdated Details for John:" << endl;
    account1.displayAccount();

    // Quick check on Account 2
    cout << "\nDetails for Sarah:" << endl;
    account2.displayAccount();

    return 0;
}
